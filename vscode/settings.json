{
  // ── Font ───────────────────────────────────────────────
  "editor.fontFamily": "JetBrainsMono Nerd Font, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontWeight": "normal",

  // ── Editor feel ────────────────────────────────────────
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": false,
  "editor.guides.bracketPairs": false,
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "none",
  "editor.scrollBeyondLastLine": false,
  "editor.overviewRulerBorder": false,
  "editor.stickyScroll.enabled": false,
  "editor.padding.top": 14,
  "editor.semanticHighlighting.enabled": false,
  "breadcrumbs.enabled": false,

  // ── Workbench / window ─────────────────────────────────
  "workbench.colorTheme": "Dark Modern",
  "workbench.startupEditor": "none",
  "workbench.list.smoothScrolling": true,
  "workbench.tree.indent": 16,
  "window.titleBarStyle": "custom",
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,
  "explorer.compactFolders": false,
  "telemetry.telemetryLevel": "off",

  // ── Terminal ───────────────────────────────────────────
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.gpuAcceleration": "on",

  // ── Monochrome UI ──────────────────────────────────────
  "workbench.colorCustomizations": {
    "editor.background": "#0a0a0b",
    "editor.foreground": "#d4d4d6",
    "editorLineNumber.foreground": "#3a3a40",
    "editorLineNumber.activeForeground": "#e8e8e8",
    "editorCursor.foreground": "#e8e8e8",
    "editor.selectionBackground": "#2a2a2e",
    "editor.selectionHighlightBackground": "#1d1d2080",
    "editor.lineHighlightBackground": "#121214",
    "editor.lineHighlightBorder": "#00000000",
    "editorIndentGuide.background1": "#1a1a1d",
    "editorIndentGuide.activeBackground1": "#2f2f34",
    "editorBracketMatch.background": "#00000000",
    "editorBracketMatch.border": "#5a5a60",
    "editorWhitespace.foreground": "#26262a",
    "sideBar.background": "#0d0d0f",
    "sideBar.foreground": "#b4b4b8",
    "sideBar.border": "#16161a",
    "sideBarSectionHeader.background": "#0d0d0f",
    "sideBarTitle.foreground": "#8a8a90",
    "activityBar.background": "#0a0a0b",
    "activityBar.foreground": "#e8e8e8",
    "activityBar.inactiveForeground": "#5a5a60",
    "activityBar.border": "#16161a",
    "activityBarBadge.background": "#e8e8e8",
    "activityBarBadge.foreground": "#0a0a0b",
    "statusBar.background": "#0a0a0b",
    "statusBar.foreground": "#8a8a90",
    "statusBar.border": "#16161a",
    "statusBar.noFolderBackground": "#0a0a0b",
    "statusBar.debuggingBackground": "#e8e8e8",
    "statusBar.debuggingForeground": "#0a0a0b",
    "titleBar.activeBackground": "#0a0a0b",
    "titleBar.activeForeground": "#d4d4d6",
    "titleBar.inactiveBackground": "#0a0a0b",
    "titleBar.inactiveForeground": "#5a5a60",
    "titleBar.border": "#16161a",
    "tab.activeBackground": "#141416",
    "tab.activeForeground": "#e8e8e8",
    "tab.inactiveBackground": "#0a0a0b",
    "tab.inactiveForeground": "#5a5a60",
    "tab.activeBorderTop": "#e8e8e8",
    "tab.activeBorder": "#00000000",
    "tab.border": "#0a0a0b",
    "editorGroupHeader.tabsBackground": "#0a0a0b",
    "editorGroupHeader.tabsBorder": "#16161a",
    "panel.background": "#0a0a0b",
    "panel.border": "#1f1f23",
    "panelTitle.activeForeground": "#e8e8e8",
    "panelTitle.inactiveForeground": "#5a5a60",
    "terminal.background": "#0a0a0b",
    "terminal.foreground": "#d4d4d6",
    "terminalCursor.foreground": "#e8e8e8",
    "focusBorder": "#2a2a2e",
    "widget.shadow": "#00000066",
    "input.background": "#141416",
    "input.border": "#2a2a2e",
    "input.foreground": "#e8e8e8",
    "dropdown.background": "#141416",
    "dropdown.border": "#2a2a2e",
    "list.activeSelectionBackground": "#1d1d20",
    "list.activeSelectionForeground": "#e8e8e8",
    "list.inactiveSelectionBackground": "#141416",
    "list.hoverBackground": "#141416",
    "list.focusBackground": "#1d1d20",
    "quickInput.background": "#0d0d0f",
    "quickInputList.focusBackground": "#1d1d20",
    "menu.background": "#0d0d0f",
    "menu.foreground": "#d4d4d6",
    "menu.selectionBackground": "#1d1d20",
    "menu.border": "#2a2a2e",
    "editorWidget.background": "#0d0d0f",
    "editorWidget.border": "#2a2a2e",
    "editorSuggestWidget.background": "#0d0d0f",
    "editorSuggestWidget.selectedBackground": "#1d1d20",
    "editorHoverWidget.background": "#0d0d0f",
    "peekViewEditor.background": "#0d0d0f",
    "scrollbarSlider.background": "#2a2a2e66",
    "scrollbarSlider.hoverBackground": "#3a3a4099",
    "scrollbarSlider.activeBackground": "#4a4a50cc",
    "button.background": "#e8e8e8",
    "button.foreground": "#0a0a0b",
    "button.hoverBackground": "#ffffff",
    "button.secondaryBackground": "#1d1d20",
    "button.secondaryForeground": "#d4d4d6",
    "badge.background": "#2a2a2e",
    "badge.foreground": "#e8e8e8",
    "progressBar.background": "#e8e8e8",
    "gitDecoration.modifiedResourceForeground": "#a8a8ae",
    "gitDecoration.untrackedResourceForeground": "#8a8a90",
    "gitDecoration.deletedResourceForeground": "#6a6a70",
    "gitDecoration.ignoredResourceForeground": "#45454a",
    "minimap.background": "#0a0a0b",
    "breadcrumb.background": "#0a0a0b",
    "editorGutter.modifiedBackground": "#6a6a70",
    "editorGutter.addedBackground": "#9a9aa0",
    "editorGutter.deletedBackground": "#45454a"
  },

  // ── Monochrome syntax (shades of grey for depth) ───────
  "editor.tokenColorCustomizations": {
    "comments": "#56565c",
    "textMateRules": [
      { "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "foreground": "#56565c", "fontStyle": "italic" } },
      { "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier", "keyword.operator.new", "keyword.operator.expression"],
        "settings": { "foreground": "#f2f2f2", "fontStyle": "bold" } },
      { "scope": ["string", "string.quoted", "punctuation.definition.string", "string.template"],
        "settings": { "foreground": "#a6a6ac" } },
      { "scope": ["constant.numeric", "constant.language", "constant.character", "constant.language.boolean"],
        "settings": { "foreground": "#9a9aa0" } },
      { "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
        "settings": { "foreground": "#ededf0" } },
      { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "entity.name.namespace"],
        "settings": { "foreground": "#cdcdd2", "fontStyle": "italic" } },
      { "scope": ["variable", "variable.other", "variable.other.readwrite", "meta.definition.variable"],
        "settings": { "foreground": "#d4d4d6" } },
      { "scope": ["variable.parameter", "variable.other.property"],
        "settings": { "foreground": "#bcbcc2", "fontStyle": "italic" } },
      { "scope": ["variable.other.constant", "constant.other", "support.constant"],
        "settings": { "foreground": "#cfcfd4" } },
      { "scope": ["keyword.operator", "punctuation", "meta.brace"],
        "settings": { "foreground": "#8a8a90" } },
      { "scope": ["entity.name.tag", "support.type.property-name"],
        "settings": { "foreground": "#e8e8e8" } },
      { "scope": ["entity.other.attribute-name"],
        "settings": { "foreground": "#a6a6ac", "fontStyle": "italic" } },
      { "scope": ["markup.heading", "markup.bold"],
        "settings": { "foreground": "#f2f2f2", "fontStyle": "bold" } },
      { "scope": ["markup.italic"],
        "settings": { "fontStyle": "italic" } },
      { "scope": ["invalid"],
        "settings": { "foreground": "#d06060" } }
    ]
  }
}
