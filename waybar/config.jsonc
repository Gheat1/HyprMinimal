{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,
  "spacing": 4,

  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["group/controls", "tray", "group/hardware"],

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["custom/brightness", "pulseaudio", "network", "custom/power"]
  },

  "group/controls": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "transition-left-to-right": true,
      "click-to-reveal": true,
      "children-class": "control-item"
    },
    "modules": ["custom/menu", "custom/tools", "custom/claudeoclock", "custom/lowpower", "custom/profile"]
  },

  "custom/menu": {
    "format": "ůįćú",
    "tooltip-format": "Controls ‚ÄĒ click to expand"
  },

  "custom/brightness": {
    "exec": "~/.config/hypr/scripts/brightness.sh status",
    "return-type": "json",
    "interval": "once",
    "signal": 8,
    "format": "{}",
    "on-scroll-up": "~/.config/hypr/scripts/brightness.sh up",
    "on-scroll-down": "~/.config/hypr/scripts/brightness.sh down"
  },

  "custom/tools": {
    "format": "Ôā≠",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/tools-menu.sh"
  },


  "custom/claudeoclock": {
    "format": "ůįö©",
    "tooltip-format": "Claude'O'Clock ‚ÄĒ click to show/hide",
    "on-click": "~/.config/claudeoclock/toggle.sh"
  },

  "custom/lowpower": {
    "exec": "~/.config/waybar/scripts/lowpower.sh status",
    "return-type": "json",
    "interval": 30,
    "signal": 9,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/lowpower.sh toggle"
  },

  "custom/profile": {
    "exec": "~/.config/waybar/scripts/profile.sh status",
    "return-type": "json",
    "interval": 5,
    "format": "{}",
    "on-click": "~/.config/waybar/scripts/profile.sh next"
  },

  "custom/power": {
    "exec": "~/.config/waybar/scripts/power.sh",
    "return-type": "json",
    "interval": 60,
    "format": "{}",
    "on-click": "blueman-manager || overskride || solaar"
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true,
    "persistent-workspaces": { "*": 5 }
  },

  "hyprland/window": {
    "format": "{title}",
    "max-length": 60,
    "separate-outputs": true
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%a %d %b}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "today": "<span color='#e8e8e8'><b>{}</b></span>"
      }
    }
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "ůįĚü",
    "format-icons": { "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"] },
    "tooltip-format": "{volume}%  ¬∑  {desc}",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": ["ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"],
    "format-ethernet": "ůįąÄ",
    "format-disconnected": "ůįĖ™",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)  ¬∑  click to pick a network",
    "tooltip-format-ethernet": "{ifname}  ¬∑  wired",
    "tooltip-format-disconnected": "Offline  ¬∑  click to connect",
    "on-click": "~/.config/waybar/scripts/wifi-menu.sh",
    "on-click-right": "nm-connection-editor"
  },

  "battery": {
    "states": { "warning": 25, "critical": 10 },
    "format": "{icon} {capacity}%",
    "format-charging": "ůįāĄ {capacity}%",
    "format-plugged": "ůįö• {capacity}%",
    "format-icons": ["ůįāé", "ůįĀļ", "ůįĀľ", "ůįĀĺ", "ůįāÄ", "ůįāā", "ůįĀĻ"],
    "interval": 30
  },

  "tray": {
    "icon-size": 16,
    "spacing": 10
  }
}
